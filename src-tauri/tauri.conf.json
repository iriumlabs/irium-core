{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "Irium Core",
    "version": "1.0.4"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "execute": false,
        "sidecar": true,
        "open": true,
        "scope": [
          {
            "name": "iriumd",
            "sidecar": true
          },
          {
            "name": "irium-wallet",
            "sidecar": true
          },
          {
            "name": "irium-miner",
            "sidecar": true
          },
          {
            "name": "irium-explorer",
            "sidecar": true
          }
        ]
      },
      "http": {
        "all": false,
        "request": true,
        "scope": [
          "http://127.0.0.1:38300/**",
          "https://127.0.0.1:38300/**",
          "http://localhost:38300/**",
          "http://localhost:5173/**",
          "http://127.0.0.1:38310/**"
        ]
      },
      "window": {
        "all": true
      },
      "path": {
        "all": true
      },
      "fs": {
        "all": false,
        "readFile": true,
        "writeFile": true,
        "readDir": true,
        "createDir": true,
        "exists": true,
        "scope": ["$APPDATA/**", "$HOME/.irium/**", "$RESOURCE/*"]
      },
      "process": {
        "all": true
      },
      "dialog": {
        "open": true,
        "save": true
      },
      "notification": {
        "all": false
      },
      "clipboard": {
        "all": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.iriumlabs.core",
      "publisher": "Irium Labs",
      "category": "Finance",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.ico",
        "icons/icon.png"
      ],
      "resources": ["icons/icon.png"],
      "externalBin": [
        "binaries/iriumd",
        "binaries/irium-wallet",
        "binaries/irium-miner",
        "binaries/irium-explorer"
      ],
      "longDescription": "Irium Core is the official full-node desktop wallet and miner for the Irium (IRM) blockchain. It bundles an embedded full node (iriumd), a non-custodial BIP39 HD wallet, CPU and GPU mining, ASIC and Stratum pool support, an in-app block explorer, and a settlement UI in a single native window. Your keys never leave your machine; all node operations go through a locally-spawned iriumd on loopback RPC.",
      "shortDescription": "Full-node desktop wallet and miner for the Irium blockchain",
      "windows": {
        "wix": {
          "language": "en-US",
          "bannerPath": "icons/installer-banner.bmp",
          "dialogImagePath": "icons/installer-dialog.bmp"
        },
        "nsis": {
          "installerIcon": "icons/icon.ico",
          "headerImage": "icons/nsis-header.bmp",
          "sidebarImage": "icons/nsis-sidebar.bmp"
        }
      },
      "macOS": {
        "minimumSystemVersion": "10.15",
        "exceptionDomain": "localhost"
      },
      "deb": {
        "depends": ["libwebkit2gtk-4.0-37", "libgtk-3-0", "libssl1.1 | libssl3"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: asset: https://asset.localhost"
    },
    "systemTray": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": false
    },
    "updater": {
      "active": true,
      "endpoints": ["https://github.com/iriumlabs/irium-core/releases/latest/download/latest.json"],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM1Q0FEMjM3MzY1NTY4Q0EKUldUS2FGVTJOOUxLeFkvbml4WnJzMkVsZ29IVTZ6S0k4YnFWUUQxNk1Tc2UwaHBiNEs3U0h6d2EK"
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Irium Core",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 680,
        "center": true,
        "decorations": false,
        "transparent": false,
        "fileDropEnabled": false
      }
    ]
  }
}
